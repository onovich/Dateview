<Window x:Class="ChinaTrayCalendar.Desktop.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:desktop="clr-namespace:ChinaTrayCalendar.Desktop"
        Title="{x:Static desktop:DesktopStrings.SettingsTitle}"
        Width="360"
        Height="260"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner">
    <Border Padding="18" Background="#FFF9FAFB">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="116" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Margin="0,0,12,12"
                       VerticalAlignment="Center"
                       Text="{x:Static desktop:DesktopStrings.SettingsFirstDayOfWeek}" />
            <ComboBox Grid.Row="0"
                      Grid.Column="1"
                      Margin="0,0,0,12"
                      DisplayMemberPath="Label"
                      ItemsSource="{Binding FirstDayOptions}"
                      SelectedItem="{Binding SelectedFirstDayOfWeek, Mode=TwoWay}" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Margin="0,0,12,12"
                       VerticalAlignment="Center"
                       Text="{x:Static desktop:DesktopStrings.SettingsTheme}" />
            <TextBox Grid.Row="1"
                     Grid.Column="1"
                     Margin="0,0,0,12"
                     IsEnabled="False"
                     Text="{Binding ThemeLabel}" />

            <CheckBox Grid.Row="2"
                      Grid.Column="1"
                      Margin="0,2,0,12"
                      Content="{x:Static desktop:DesktopStrings.SettingsStartWithWindows}"
                      IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />

            <TextBlock Grid.Row="3"
                       Grid.ColumnSpan="2"
                       Foreground="#B91C1C"
                       Text="{Binding ErrorMessage}" />

            <StackPanel Grid.Row="4"
                        Grid.ColumnSpan="2"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <Button MinWidth="76"
                        Margin="0,0,8,0"
                        Command="{Binding CancelCommand}"
                        Content="{x:Static desktop:DesktopStrings.SettingsCancel}" />
                <Button MinWidth="76"
                        Command="{Binding SaveCommand}"
                        Content="{x:Static desktop:DesktopStrings.SettingsSave}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
