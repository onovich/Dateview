<Window x:Class="ChinaTrayCalendar.Desktop.CalendarPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:domain="clr-namespace:ChinaTrayCalendar.Domain;assembly=ChinaTrayCalendar.Domain"
        Title="Dateview"
        Width="360"
        Height="420"
        MinWidth="360"
        MinHeight="420"
        MaxWidth="360"
        MaxHeight="420"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14000000" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="8"
            Padding="16"
            Background="#FFFDFDFD"
            BorderBrush="#1F000000"
            BorderThickness="1"
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              Direction="270"
                              Opacity="0.18"
                              ShadowDepth="4" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="28" />
                <RowDefinition Height="*" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding PreviousMonthCommand}"
                            Content="‹"
                            ToolTip="上个月" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding TodayCommand}"
                            Content="今"
                            ToolTip="回到今天" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding NextMonthCommand}"
                            Content="›"
                            ToolTip="下个月" />
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding CloseCommand}"
                            Content="×"
                            ToolTip="关闭" />
                </StackPanel>

                <TextBlock VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Text="{Binding MonthTitle}" />
            </DockPanel>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding WeekdayHeaders}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7" Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#6B7280"
                                   Text="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl Grid.Row="2" ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7" Rows="6" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="CellBorder"
                                Margin="2"
                                Padding="4"
                                Background="#00FFFFFF"
                                BorderBrush="#00FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <TextBlock x:Name="DayNumber"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"
                                           Text="{Binding Date.Day}" />

                                <Border x:Name="Badge"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        MinWidth="18"
                                        Height="18"
                                        Padding="4,0"
                                        Background="#EEF2FF"
                                        CornerRadius="9"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="BadgeText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#3730A3" />
                                </Border>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsInCurrentMonth}" Value="False">
                                <Setter TargetName="CellBorder" Property="Opacity" Value="0.42" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsWeekend}" Value="True">
                                <Setter TargetName="DayNumber" Property="Foreground" Value="#A16207" />
                                <Setter TargetName="Badge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Badge" Property="Background" Value="#FEF3C7" />
                                <Setter TargetName="BadgeText" Property="Foreground" Value="#92400E" />
                                <Setter TargetName="BadgeText" Property="Text" Value="末" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Marker}" Value="{x:Static domain:DayMarker.DayOff}">
                                <Setter TargetName="Badge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Badge" Property="Background" Value="#DCFCE7" />
                                <Setter TargetName="BadgeText" Property="Foreground" Value="#166534" />
                                <Setter TargetName="BadgeText" Property="Text" Value="休" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Marker}" Value="{x:Static domain:DayMarker.AdjustedWorkday}">
                                <Setter TargetName="Badge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Badge" Property="Background" Value="#FEE2E2" />
                                <Setter TargetName="BadgeText" Property="Foreground" Value="#991B1B" />
                                <Setter TargetName="BadgeText" Property="Text" Value="班" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Marker}" Value="{x:Static domain:DayMarker.FestivalOnly}">
                                <Setter TargetName="Badge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Badge" Property="Background" Value="#E0F2FE" />
                                <Setter TargetName="BadgeText" Property="Foreground" Value="#075985" />
                                <Setter TargetName="BadgeText" Property="Text" Value="节" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                <Setter TargetName="CellBorder" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="CellBorder" Property="BorderThickness" Value="2" />
                                <Setter TargetName="CellBorder" Property="Background" Value="#EFF6FF" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="3">
                <TextBlock HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                           FontSize="12"
                           Foreground="#6B7280"
                           Text="加载中...">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                           FontSize="12"
                           Foreground="#B91C1C"
                           Text="{Binding ErrorMessage}" />
            </Grid>
        </Grid>
    </Border>
</Window>
